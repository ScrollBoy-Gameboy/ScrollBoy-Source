{
  "name": "scrollboy",
  "version": "1.0.0",
  "description": "ScrollBoy The Custom GBC by Voltaccept",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start:web": "next start",
    "electron": "electron .",
    "electron:build": "electron-builder",
    "electron:build:win": "electron-builder --win",
    "electron:build:mac": "electron-builder --mac",
    "electron:build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.voltaccept.scrollboy",
    "productName": "ScrollBoy",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    }
  },
  "dependencies": {
    "next": "16.2.6",
    "nostalgist": "^0.21.1",
    "react": "^19",
    "react-dom": "^19",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "typescript": "5.7.3"
  }
}
